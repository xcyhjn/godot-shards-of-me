; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="shards-of-me"
config/version="0.0.1"
run/main_scene="res://scenes/menu/menu.tscn"
config/features=PackedStringArray("4.4")
config/icon="res://assets/images/sprites/icon.png"

[autoload]

GGT="*res://addons/ggt-core/ggt.gd"
GGT_DebugShortcuts="*res://addons/ggt-debug-shortcuts/autoload/debug_shortcuts.tscn"
EventBus="*res://scripts/EventBus.gd"
GameManager="*res://scripts/GameManager.gd"
Dialogic="*res://addons/dialogic/Core/DialogicGameHandler.gd"
ItemData="*res://scripts/ItemData.gd"
ClueManager="*res://scripts/ClueManager.gd"

[category]

property_name=1

[dialogic]

directories/dch_directory={
"ouyang_ye": "res://dialogs/ouyang_ye.dch"
}
directories/dtl_directory={
"test": "res://dialogs/test.dtl"
}
layout/style_directory={
"": "res://dialogs/style.tres",
"style": "res://dialogs/style.tres"
}
layout/style_list=["res://dialogs/style.tres"]
layout/default_style="res://dialogs/style.tres"

[display]

window/stretch/mode="canvas_items"
window/stretch/aspect="expand"
window/stretch/scale_mode="integer"

[editor_plugins]

enabled=PackedStringArray("res://addons/dialogic/plugin.cfg", "res://addons/ggt-core/plugin.cfg", "res://addons/ggt-debug-shortcuts/plugin.cfg")

[gui]

theme/custom="res://resources/theme/theme-main.tres"

